<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A1A2E">

    <!-- Progress Text -->
    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Question 1 of 10"
        android:textSize="14sp"
        android:textColor="#B0B0C0"
        android:layout_marginBottom="24dp"/>

    <!-- Flashcard -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#16213E"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- Card Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HACK OR MYTH?"
                android:textSize="11sp"
                android:textColor="#E94560"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="16dp"/>

            <!-- Statement -->
            <TextView
                android:id="@+id/tvStatement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:lineSpacingExtra="6dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Hack and Myth Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnHack"
            android:layout_width="140dp"
            android:layout_height="55dp"
            android:text=" HACK"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2ECC71"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/btnMyth"
            android:layout_width="140dp"
            android:layout_height="55dp"
            android:text=" MYTH"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E94560"/>

    </LinearLayout>

    <!-- Feedback -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/feedbackCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#16213E"
        android:layout_marginBottom="24dp"
        android:visibility="invisible">

        <TextView
            android:id="@+id/tvFeedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:padding="16dp"
            android:layout_gravity="center"/>

    </androidx.cardview.widget.CardView>

    <!-- Next Button -->
    <Button
        android:id="@+id/btnNext"
        android:layout_width="220dp"
        android:layout_height="55dp"
        android:text="NEXT ➡"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E94560"
        android:visibility="invisible"/>

</LinearLayout>
