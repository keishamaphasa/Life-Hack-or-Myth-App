<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <!-- Emoji Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧠"
        android:textSize="72sp"
        android:layout_marginBottom="16dp"/>

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Life Hack or"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#E94560"
        android:gravity="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Urban Myth?"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Divider -->
    <View
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:background="#E94560"
        android:layout_marginBottom="24dp"/>

    <!-- Description -->
    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Think you can spot the difference between a real life hack and a viral urban myth? Test your knowledge and find out if you\'re a true Life Hack Master!"
        android:textSize="15sp"
        android:textColor="#B0B0C0"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="40dp"/>

    <!-- Start Button -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="220dp"
        android:layout_height="55dp"
        android:text="START QUIZ"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#E94560"
        android:layout_marginBottom="16dp"/>

</LinearLayout>